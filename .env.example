# Database (PostgreSQL)
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/rally"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# Google OAuth (optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Anthropic Claude (for AI matching)
ANTHROPIC_API_KEY=""

# Pusher (real-time messaging)
PUSHER_APP_ID=""
PUSHER_KEY=""
PUSHER_SECRET=""
PUSHER_CLUSTER="eu"
NEXT_PUBLIC_PUSHER_KEY=""
NEXT_PUBLIC_PUSHER_CLUSTER="eu"

# ── Stripe (payments) ──────────────────────────────────────────────────────────
# Secret key — from Stripe Dashboard → Developers → API keys
STRIPE_SECRET_KEY="sk_test_..."

# Publishable key — also from API keys page
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Webhook signing secret — TWO different values depending on context:
#   Development:  run `stripe listen --forward-to localhost:3000/api/stripe/webhook`
#                 in your terminal; it prints "Your webhook signing secret is whsec_..."
#                 Paste that whsec_... value here.
#   Production:   Stripe Dashboard → Developers → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET="whsec_..."

# !! IMPORTANT: these must be PRICE IDs (price_...), NOT product IDs (prod_...) !!
# In Stripe Dashboard: Catalog → Products → click your product → copy the Price ID
# under the Pricing section. It starts with "price_", not "prod_".

# €2.50 one-time credit — "Single Rendez credit" product → its Price ID
STRIPE_MATCH_PACK_PRICE_ID="price_..."

# €11/month subscription — "Premium" product → its Price ID
STRIPE_PREMIUM_PRICE_ID="price_..."

# €1 one-time — "10 extra messages" product → its Price ID (create this product if it doesn't exist yet)
STRIPE_EXTRA_MSG_PRICE_ID="price_..."
# ───────────────────────────────────────────────────────────────────────────────

# Cron job protection
CRON_SECRET="generate-random-secret"

# App URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Vercel Blob (profile photo storage)
# In Vercel Dashboard → your project → Storage → Blob → Create Store
# then copy the BLOB_READ_WRITE_TOKEN from the .env.local it offers.
BLOB_READ_WRITE_TOKEN="vercel_blob_..."
